{
  "name": "iml_demo_dekstop",
  "version": "1.0.0",
  "main": "build/electron.cjs",
  "homepage": "./",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "electron": "electron .",
    "electron-build": "npm run build && electron-builder",
    "electron-view": "npm run build && electron .",
    "release": "react-scripts build && electron-builder --publish=always"
  },
  "build": {
    "appId": "com.example.electronapp",
    "extends": null,
    "files": [
      "build/**/*",
      "electron.cjs"
    ],
