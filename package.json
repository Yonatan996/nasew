      "buildResources": "assets"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@lottiefiles/dotlottie-react": "^0.12.3",
    "antd": "^5.23.2",
    "chart.js": "^4.4.7",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "firebase": "^11.3.0",
    "firebase-admin": "^13.3.0",
    "firebase-functions": "^6.3.2",
    "fs": "^0.0.1-security",
    "json2xls": "^0.1.2",
    "lucide-react": "^0.474.0",
    "moment": "^2.30.1",
    "nodemailer": "^6.10.0",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-datepicker": "^8.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.4.0",
    "react-lottie": "^1.2.10",
    "react-router-dom": "^7.1.3",
    "react-script": "^2.0.5",
    "react-scripts": "^5.0.1",
    "react-select": "^5.10.0",
    "recharts": "^2.15.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17"
  }
